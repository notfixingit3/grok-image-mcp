# Grok Image MCP Configuration
# Copy this file to .env and add your API key

# Free offline development — no API key or credits required
# GROK_IMAGE_MOCK=1

# Your xAI API key from https://console.x.ai (not needed when GROK_IMAGE_MOCK=1)
# XAI_API_KEY=your_xai_api_key_here

# Optional: default image model
# GROK_IMAGE_MODEL=grok-imagine-image-quality

# Optional: custom directory for saved images
# GROK_IMAGES_DIR=/path/to/your/images

# Optional: enable request logging
# GROK_IMAGE_LOG_FILE=/tmp/grok-image-mcp.log